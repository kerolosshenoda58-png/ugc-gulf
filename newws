// Bridges "role selected" -> "dropped into dashboard" with a couple of
// lightweight setup steps, themed per role, so the journey feels earned
// rather than instant.

const creatorNiches = ["Beauty", "Tech", "Fashion", "Fitness", "Food", "Home Decor", "Travel", "Parenting"];
const creatorPlatforms = ["Instagram", "TikTok", "YouTube"];
const brandGoals = ["Product launches", "Always-on UGC", "Paid ad creative", "Brand awareness"];
const brandBudgets = ["< $1,000/mo", "$1,000–$5,000/mo", "$5,000–$20,000/mo", "$20,000+/mo"];

function Chip({ label, active, onClick, accent }: { label: string; active: boolean; onClick: () => void; accent: "violet" | "orange" }) {
  return (
    <motion.button type="button" whileTap={{ scale: 0.96 }} onClick={onClick}
      className={`px-3 py-1.5 rounded-full text-xs font-semibold border transition-colors ${active
        ? accent === "violet" ? "bg-violet-600 text-white border-violet-600" : "bg-orange-500 text-white border-orange-500"
        : "bg-white text-muted-foreground border-border hover:bg-secondary"}`}>
      {label}
    </motion.button>
  );
}

function OnboardingView({ role, onComplete }: { role: "creator" | "company"; onComplete: () => void }) {
  const accent = role === "creator" ? "violet" : "orange";
  const totalSteps = 2;
  const [step, setStep] = useState(1);
  const [name, setName] = useState("");
  const [location, setLocation] = useState("");
  const [selectedNiches, setSelectedNiches] = useState<string[]>([]);
  const [selectedPlatforms, setSelectedPlatforms] = useState<string[]>([]);
  const [selectedGoals, setSelectedGoals] = useState<string[]>([]);
  const [budget, setBudget] = useState("");

  const toggle = (list: string[], setList: (v: string[]) => void, item: string) =>
    setList(list.includes(item) ? list.filter((i) => i !== item) : [...list, item]);

  const step1Valid = name.trim().length > 0 && location.trim().length > 0;
  const step2Valid = role === "creator" ? selectedNiches.length > 0 : selectedGoals.length > 0;

  return (
    <div className="min-h-screen bg-background flex items-center justify-center p-6" style={{ fontFamily: "'Plus Jakarta Sans', sans-serif" }}>
      <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} transition={{ duration: 0.4 }}
        className="w-full max-w-lg bg-white border border-border rounded-3xl shadow-lg p-7">
        {/* Progress */}
        <div className="flex items-center gap-1.5 mb-6">
          {Array.from({ length: totalSteps }).map((_, i) => (
            <div key={i} className={`h-1.5 flex-1 rounded-full ${i < step ? (accent === "violet" ? "bg-violet-600" : "bg-orange-500") : "bg-secondary"}`} />
          ))}
        </div>

        <div className="flex items-center gap-2 mb-1">
          <div className={`w-8 h-8 rounded-xl flex items-center justify-center ${accent === "violet" ? "bg-violet-100" : "bg-orange-100"}`}>
            {role === "creator" ? <Camera size={15} className="text-violet-600" /> : <Briefcase size={15} className="text-orange-600" />}
          </div>
          <p className="text-[10px] font-semibold text-muted-foreground">Step {step} of {totalSteps}</p>
        </div>

        <AnimatePresence mode="wait">
          {step === 1 && (
            <motion.div key="s1" initial={{ opacity: 0, x: 12 }} animate={{ opacity: 1, x: 0 }} exit={{ opacity: 0, x: -12 }} transition={{ duration: 0.25 }}>
              <h2 className="text-xl font-extrabold text-foreground mb-1.5">
                {role === "creator" ? "Tell us about you" : "Tell us about your company"}
              </h2>
              <p className="text-xs text-muted-foreground mb-5">
                {role === "creator" ? "This is what brands see first on your profile." : "Helps us match you with the right creators."}
              </p>
              <div className="space-y-3">
                <div>
                  <label className="text-[11px] font-semibold text-foreground mb-1 block">
                    {role === "creator" ? "Full name" : "Company name"}
                  </label>
                  <input value={name} onChange={(e) => setName(e.target.value)}
                    placeholder={role === "creator" ? "e.g. Sofia Reyes" : "e.g. NovaSkin Co."}
                    className="w-full px-3 py-2.5 rounded-xl border border-border text-sm focus:outline-none focus:ring-2 focus:ring-violet-200 focus:border-violet-400" />
                </div>
                <div>
                  <label className="text-[11px] font-semibold text-foreground mb-1 block">Location</label>
                  <input value={location} onChange={(e) => setLocation(e.target.value)}
                    placeholder="e.g. Dubai, UAE"
                    className="w-full px-3 py-2.5 rounded-xl border border-border text-sm focus:outline-none focus:ring-2 focus:ring-violet-200 focus:border-violet-400" />
                </div>
              </div>
            </motion.div>
          )}

          {step === 2 && role === "creator" && (
            <motion.div key="s2c" initial={{ opacity: 0, x: 12 }} animate={{ opacity: 1, x: 0 }} exit={{ opacity: 0, x: -12 }} transition={{ duration: 0.25 }}>
              <h2 className="text-xl font-extrabold text-foreground mb-1.5">What do you create?</h2>
              <p className="text-xs text-muted-foreground mb-4">Pick your niches — you can add more later.</p>
              <div className="flex flex-wrap gap-2 mb-5">
                {creatorNiches.map((n) => (
                  <Chip key={n} label={n} accent="violet" active={selectedNiches.includes(n)} onClick={() => toggle(selectedNiches, setSelectedNiches, n)} />
                ))}
              </div>
              <p className="text-[11px] font-semibold text-foreground mb-2">Where do you post?</p>
              <div className="flex flex-wrap gap-2">
                {creatorPlatforms.map((p) => (
                  <Chip key={p} label={p} accent="violet" active={selectedPlatforms.includes(p)} onClick={() => toggle(selectedPlatforms, setSelectedPlatforms, p)} />
                ))}
              </div>
            </motion.div>
          )}

          {step === 2 && role === "company" && (
            <motion.div key="s2b" initial={{ opacity: 0, x: 12 }} animate={{ opacity: 1, x: 0 }} exit={{ opacity: 0, x: -12 }} transition={{ duration: 0.25 }}>
              <h2 className="text-xl font-extrabold text-foreground mb-1.5">What are you hiring for?</h2>
              <p className="text-xs text-muted-foreground mb-4">This shapes which creators show up in your feed.</p>
              <div className="flex flex-wrap gap-2 mb-5">
                {brandGoals.map((g) => (
                  <Chip key={g} label={g} accent="orange" active={selectedGoals.includes(g)} onClick={() => toggle(selectedGoals, setSelectedGoals, g)} />
                ))}
              </div>
              <p className="text-[11px] font-semibold text-foreground mb-2">Monthly UGC budget</p>
              <div className="flex flex-wrap gap-2">
                {brandBudgets.map((b) => (
                  <Chip key={b} label={b} accent="orange" active={budget === b} onClick={() => setBudget(b)} />
                ))}
              </div>
            </motion.div>
          )}
        </AnimatePresence>

        {/* Nav buttons */}
        <div className="flex items-center justify-between mt-7">
          {step > 1 ? (
            <button onClick={() => setStep(step - 1)} className="text-xs font-semibold text-muted-foreground hover:text-foreground px-3 py-2">
              ← Back
            </button>
          ) : <span />}
          <motion.button whileTap={{ scale: 0.97 }}
            disabled={step === 1 ? !step1Valid : !step2Valid}
            onClick={() => (step < totalSteps ? setStep(step + 1) : onComplete())}
            className={`flex items-center gap-1.5 px-5 py-2.5 rounded-xl text-sm font-semibold text-white transition-all disabled:opacity-40 disabled:cursor-not-allowed ${accent === "violet" ? "bg-violet-600 hover:bg-violet-700 shadow-sm shadow-violet-200" : "bg-orange-500 hover:bg-orange-600 shadow-sm shadow-orange-200"}`}>
            {step < totalSteps ? "Continue" : "Enter dashboard"}<ArrowRight size={14} />
          </motion.button>
        </div>
      </motion.div>
    </div>
  );
}

