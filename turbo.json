{
  "extends": ["//"],
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": ["**/.env.local", "**/package.json"],
  "pipeline": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "test": {
      "outputs": ["coverage/**"],
      "cache": false
    },
    "lint": {
      "cache": false
    }
  }
}
